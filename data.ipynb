    "class DynamicArray:\n",
    "    def __init__(self):\n",
    "        self.capacity = 1\n",
    "        self.count = 0\n",
    "        self.array = [None] * self.capacity\n",
    "\n",
    "    def _resize(self, new_capacity):\n",
    "        new_array = [None] * new_capacity\n",
    "        for i in range(self.count):\n",
    "            new_array[i] = self.array[i]\n",
    "        self.array = new_array\n",
    "        self.capacity = new_capacity\n",
    "\n",
    "    def append(self, value):\n",
    "        if self.count == self.capacity:\n",
    "            self._resize(self.capacity * 2)\n",
    "        self.array[self.count] = value\n",
    "        self.count += 1\n",
    "\n",
    "    def get(self, index):\n",
    "        if 0 <= index < self.count:\n",
    "            return self.array[index]\n",
    "        raise IndexError(\"Index out of range\")\n",
    "\n",
    "    def set(self, index, value):\n",
    "        if 0 <= index < self.count:\n",
    "            self.array[index] = value\n",
    "        else:\n",
    "            raise IndexError(\"Index out of range\")\n",
    "\n",
    "    def insert(self, index, value):\n",
    "        if self.count == self.capacity:\n",
    "            self._resize(self.capacity * 2)\n",
    "        for i in range(self.count, index, -1):\n",
    "            self.array[i] = self.array[i-1]\n",
    "        self.array[index] = value\n",
    "        self.count += 1\n",
    "\n",
    "    def delete(self, index):\n",
    "        for i in range(index, self.count-1):\n",
    "            self.array[i] = self.array[i+1]\n",
    "        self.array[self.count-1] = None\n",
    "        self.count -= 1\n",
    "\n",
    "    def size(self):\n",
    "        return self.count\n",
    "\n",
    "    def display(self):\n",
    "        return [self.array[i] for i in range(self.count)]\n",
    "\n",
    "# Bioinformatics Example\n",
    "dna = DynamicArray()\n",
    "for base in [\"A\",\"T\",\"G\",\"C\",\"A\",\"G\",\"T\"]:\n",
    "    dna.append(base)\n",
    "\n",
    "print(\"Original:\", dna.display())\n",
    "print(\"Access pos 3:\", dna.get(2))\n",
    "dna.insert(3, \"X\")\n",
    "print(\"After insert:\", dna.display())\n",
    "dna.delete(1)\n",
    "print(\"After delete:\", dna.display())\n",
    "dna.set(0, \"C\")\n",
    "print(\"After replace:\", dna.display())"
   ]
