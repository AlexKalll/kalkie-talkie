    "class Stack:\n",
    "    def __init__(self):\n",
    "        self.items = []\n",
    "\n",
    "    def push(self, item):\n",
    "        self.items.append(item)\n",
    "\n",
    "    def pop(self):\n",
    "        if not self.is_empty():\n",
    "            return self.items.pop()\n",
    "\n",
    "    def peek(self):\n",
    "        return self.items[-1] if not self.is_empty() else None\n",
    "\n",
    "    def is_empty(self):\n",
    "        return len(self.items) == 0\n",
    "\n",
    "    def size(self):\n",
    "        return len(self.items)\n",
    "\n",
    "# Bioinformatics Example\n",
    "traceback = Stack()\n",
    "for op in [\"Match\",\"Match\",\"Insertion\",\"Match\",\"Deletion\"]:\n",
    "    traceback.push(op)\n",
    "\n",
    "print(\"Stack:\", traceback.items)\n",
    "while not traceback.is_empty():\n",
    "    print(\"Pop:\", traceback.pop())"
   ]
